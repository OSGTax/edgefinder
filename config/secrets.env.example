# ============================================================
# EdgeFinder API Keys
# ============================================================
# Copy this file to: config/secrets.env
# Fill in your keys below. This file is .gitignored (never committed).
#
# SETUP GUIDE:
#   1. Copy:  cp config/secrets.env.example config/secrets.env
#   2. Edit:  nano config/secrets.env  (or open in any text editor)
#   3. Paste your keys where indicated
#   4. Save and close
#   5. Run:   python scripts/verify_data_service.py
# ============================================================

# ── ALPACA (Paper Trading — FREE) ──────────────────────────
# Sign up at: https://alpaca.markets
# Switch to "Paper Trading" mode in the dashboard
# Go to: API Keys → Generate New Key
# You'll get two values — paste them below (no quotes needed)

ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── FMP (Financial Modeling Prep — FREE TIER) ──────────────
# Sign up at: https://site.financialmodelingprep.com/developer
# Free tier: 250 requests/day (we cache aggressively to stay under)
# Copy your API key from the dashboard

FMP_API_KEY=your_fmp_api_key_here
